#!/bin/sh
# use-secret — CLI stub for sponsor secrets (privileged handler pattern)
#
# This script runs INSIDE the sandbox container. It does NOT have access to
# plaintext secret values. Instead, it sends a proxy request to the Worker,
# which resolves the secret and makes the external API call with injected
# credentials. The secret value never enters the sandbox environment.
#
# Usage:
#   use-secret <NAME> <INJECTION_MODE> <URL> [METHOD] [BODY]
#
# Examples:
#   use-secret GITHUB_TOKEN bearer https://api.github.com/user
#   use-secret API_KEY header:X-Api-Key https://api.example.com/data
#   use-secret STRIPE_KEY bearer https://api.stripe.com/v1/charges POST '{"amount":100}'
#   use-secret DB_PASSWORD query:password https://db.example.com/query
#
# Injection modes:
#   bearer          - Authorization: Bearer <secret>
#   basic           - Authorization: Basic <base64(secret)>
#   header:<name>   - Custom header with secret value
#   query:<param>   - Query parameter with secret value
#   body:<field>    - JSON body field with secret value
#
# Environment variables (set by the Worker):
#   WORKER_URL              - URL of the Worker (required)
#   OPENCLAW_GATEWAY_TOKEN  - Gateway token for auth (required)
#   ORGANISM_ID             - Organism ID (optional, defaults to 'default')
#
# Exit codes:
#   0 - Success (response body printed to stdout)
#   1 - Usage error
#   2 - Missing configuration
#   3 - Request failed

set -e

# Parse arguments
NAME="$1"
MODE="$2"
URL="$3"
METHOD="${4:-GET}"
BODY="$5"

if [ -z "$NAME" ] || [ -z "$MODE" ] || [ -z "$URL" ]; then
  echo "Usage: use-secret <NAME> <INJECTION_MODE> <URL> [METHOD] [BODY]" >&2
  echo "" >&2
  echo "Examples:" >&2
  echo "  use-secret GITHUB_TOKEN bearer https://api.github.com/user" >&2
  echo "  use-secret API_KEY header:X-Api-Key https://api.example.com/data" >&2
  exit 1
fi

# Check required env vars
if [ -z "$WORKER_URL" ]; then
  echo "Error: WORKER_URL is not set" >&2
  exit 2
fi

if [ -z "$OPENCLAW_GATEWAY_TOKEN" ]; then
  echo "Error: OPENCLAW_GATEWAY_TOKEN is not set" >&2
  exit 2
fi

ORG_ID="${ORGANISM_ID:-default}"

# Build JSON payload
if [ -n "$BODY" ]; then
  PAYLOAD=$(printf '{"name":"%s","injection_mode":"%s","url":"%s","method":"%s","organism_id":"%s","body":"%s"}' \
    "$NAME" "$MODE" "$URL" "$METHOD" "$ORG_ID" "$(echo "$BODY" | sed 's/"/\\"/g')")
else
  PAYLOAD=$(printf '{"name":"%s","injection_mode":"%s","url":"%s","method":"%s","organism_id":"%s"}' \
    "$NAME" "$MODE" "$URL" "$METHOD" "$ORG_ID")
fi

# Call the Worker's secret proxy endpoint
RESPONSE=$(curl -s -w '\n%{http_code}' \
  -X POST \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $OPENCLAW_GATEWAY_TOKEN" \
  -d "$PAYLOAD" \
  "${WORKER_URL}/secrets/proxy" 2>/dev/null)

# Split response body and status code
HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
RESPONSE_BODY=$(echo "$RESPONSE" | sed '$d')

# Parse the proxy response envelope
# The Worker returns: { status, headers, body }
if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
  # Extract the inner body from the proxy response
  # Uses simple string extraction since jq may not be available
  echo "$RESPONSE_BODY"
  exit 0
else
  echo "Error: Secret proxy returned HTTP $HTTP_CODE" >&2
  echo "$RESPONSE_BODY" >&2
  exit 3
fi
